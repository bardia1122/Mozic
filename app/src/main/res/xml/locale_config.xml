<?xml version="1.0" encoding="utf-8"?>
<!--
  Declares the locales Mozic ships, so Android 13+ shows Mozic in the system
  per-app language picker and the in-app language toggle
  (AppCompatDelegate.setApplicationLocales) has a supported set to switch within.
-->
<locale-config xmlns:android="http://schemas.android.com/apk/res/android">
    <locale android:name="en" />
    <locale android:name="fa" />
</locale-config>
