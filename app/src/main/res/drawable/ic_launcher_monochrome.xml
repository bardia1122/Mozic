<?xml version="1.0" encoding="utf-8"?>
<!--
  Monochrome layer for Android 13+ themed icons: the note silhouette in a single
  opaque tone on a transparent field. The launcher re-tints it to the system theme.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:pivotX="580"
        android:pivotY="542"
        android:scaleX="0.09"
        android:scaleY="0.09"
        android:translateX="-526"
        android:translateY="-488">

        <!-- Stem -->
        <path
            android:fillColor="#FF000000"
            android:pathData="M497,260 a27,27 0 0 1 27,27 v376 a27,27 0 0 1 -27,27 a27,27 0 0 1 -27,-27 v-376 a27,27 0 0 1 27,-27 z" />

        <!-- Note head (rotated ellipse) -->
        <group
            android:pivotX="430"
            android:pivotY="730"
            android:rotation="-18">
            <path
                android:fillColor="#FF000000"
                android:pathData="M312,730 a118,92 0 1 0 236,0 a118,92 0 1 0 -236,0 z" />
        </group>

        <!-- Flag -->
        <path
            android:fillColor="#FF000000"
            android:pathData="M524,268 C700,268 812,360 846,520 C862,592 848,656 806,706 C792,722 772,706 778,686 C800,610 792,542 748,486 C706,432 610,398 524,398 Z" />
    </group>
</vector>
